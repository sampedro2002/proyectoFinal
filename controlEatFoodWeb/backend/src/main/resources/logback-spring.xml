<?xml version="1.0" encoding="UTF-8"?>
<!--
  Configuración de logging del backend.

  · Perfil por defecto (dev): consola coloreada, nivel DEBUG para com.eatfood.
  · Perfil prod: dos archivos rotados (application.log + error.log) envueltos
    en AsyncAppender para no bloquear hilos de Tomcat. Rotación diaria y por
    tamaño, histórico acotado (30 / 90 días) y total cap (1 GB / 500 MB).
    La consola se mantiene en WARN solo para que NSSM capture lo mínimo
    indispensable (banner de arranque, errores nativos tempranos de JVM/Flyway).

  Los archivos se escriben bajo ./logs/ relativo al directorio de trabajo del
  servicio (AppDirectory, fijado por NSSM a $BackendDir). En producción eso es
  controlEatFoodWeb/backend/logs/.
-->
<configuration scan="false">

    <!-- Defaults de Spring Boot: registran la conversion word %clr (colores) que usa
         PATTERN_CONSOLE. Sin este include, Logback aborta con "no conversion class
         registered for [clr]" y la aplicación (y los tests) no arrancan. -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <!-- ====== Patrones ====== -->
    <property name="PATTERN_FILE"
              value="%d{ISO8601, America/Guayaquil} %-5level [%15.15thread] %X{reqId:-} %X{user:-} %X{ip:-} %-36.36logger{36} · %msg%n%ex"/>
    <property name="PATTERN_CONSOLE"
              value="%d{HH:mm:ss.SSS} %-5level [%15.15thread] %X{reqId:-} %clr(%-36.36logger{36}){cyan} · %clr(%msg){white}%n%ex"/>
    <property name="LOG_DIR" value="logs"/>

    <!-- ====== Dev: consola coloreada ====== -->
    <springProfile name="!prod">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
                <pattern>${PATTERN_CONSOLE}</pattern>
            </encoder>
        </appender>

        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
        <logger name="com.eatfood" level="DEBUG"/>
        <logger name="org.springframework.security" level="WARN"/>
    </springProfile>

    <!-- ====== Prod: archivos rotados asíncronos ====== -->
    <springProfile name="prod">
        <!-- App principal: todos los niveles -->
        <appender name="APP_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>${LOG_DIR}/application.log</file>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>${LOG_DIR}/application.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
                <maxFileSize>50MB</maxFileSize>
                <maxHistory>30</maxHistory>
                <totalSizeCap>1GB</totalSizeCap>
                <cleanHistoryOnStart>true</cleanHistoryOnStart>
            </rollingPolicy>
            <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
                <pattern>${PATTERN_FILE}</pattern>
            </encoder>
        </appender>

        <!-- App de errores: solo ERROR -->
        <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>${LOG_DIR}/error.log</file>
            <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
                <level>ERROR</level>
            </filter>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>${LOG_DIR}/error.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
                <maxFileSize>50MB</maxFileSize>
                <maxHistory>90</maxHistory>
                <totalSizeCap>500MB</totalSizeCap>
                <cleanHistoryOnStart>true</cleanHistoryOnStart>
            </rollingPolicy>
            <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
                <pattern>${PATTERN_FILE}</pattern>
            </encoder>
        </appender>

        <!-- Wrappers asíncronos para no bloquear hilos de request -->
        <appender name="ASYNC_APP" class="ch.qos.logback.classic.AsyncAppender">
            <queueSize>512</queueSize>
            <discardingThreshold>0</discardingThreshold>
            <neverBlock>true</neverBlock>
            <appender-ref ref="APP_FILE"/>
        </appender>
        <appender name="ASYNC_ERROR" class="ch.qos.logback.classic.AsyncAppender">
            <queueSize>256</queueSize>
            <discardingThreshold>0</discardingThreshold>
            <neverBlock>true</neverBlock>
            <appender-ref ref="ERROR_FILE"/>
        </appender>

        <!-- Consola mínima para NSSM (banner arranque + errores nativos puntuales) -->
        <appender name="CONSOLE_MIN" class="ch.qos.logback.core.ConsoleAppender">
            <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
                <level>WARN</level>
            </filter>
            <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
                <pattern>%d{ISO8601, America/Guayaquil} %-5level [%thread] %-36.36logger{36} · %msg%n%ex</pattern>
            </encoder>
        </appender>

        <root level="WARN">
            <appender-ref ref="CONSOLE_MIN"/>
            <appender-ref ref="ASYNC_APP"/>
            <appender-ref ref="ASYNC_ERROR"/>
        </root>
        <logger name="com.eatfood" level="INFO"/>
        <logger name="org.springframework.security" level="WARN"/>
    </springProfile>

</configuration>